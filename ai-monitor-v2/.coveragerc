[run]
# 覆盖率配置文件
source = core, api, tests
omit = 
    venv/*
    */venv/*
    */site-packages/*
    */test*
    setup.py
    conftest.py
    */migrations/*
    */static/*
    */templates/*

[report]
# 报告配置
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstract

show_missing = True
skip_covered = False
precision = 2

[html]
# HTML报告配置
directory = htmlcov
title = AI监理系统v2.1 - 测试覆盖率报告

[xml]
# XML报告配置（CI/CD集成）
output = coverage.xml